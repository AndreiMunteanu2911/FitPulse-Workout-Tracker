# Supabase Configuration
# Get these values from your Supabase project settings

SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Public keys (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenRouter API Key
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# Supabase Service Role Key (required for admin scripts like form rule generation)
# Get from Supabase Dashboard > Settings > API > service_role key
# NEVER expose this to the browser / client-side code
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Chat model (primary and fallback)
OPENROUTER_CHAT_MODEL=qwen/qwen3.6-plus:free
OPENROUTER_FALLBACK_MODEL=stepfun/step-3.5-flash:free

# Embedding model (produces vectors for pgvector)
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
